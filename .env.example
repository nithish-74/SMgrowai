# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# Auth.js v5 — https://authjs.dev/getting-started/deployment
AUTH_SECRET=generate_with_npx_auth_secret
AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Instagram OAuth — https://developers.facebook.com/docs/instagram-basic-display-api
AUTH_INSTAGRAM_ID=
AUTH_INSTAGRAM_SECRET=

# Twitter / X OAuth 2.0 — https://developer.x.com/en/docs/authentication/oauth-2-0
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# Neon Postgres — https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Upstash Redis (Bull MQ) — https://upstash.com
UPSTASH_REDIS_HOST=
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=
# Optional: use a single connection URL instead of host/port/password
# UPSTASH_REDIS_URL=rediss://default:password@host:6379

# Upstash REST API URL and token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Claude API (required for generate worker)
ANTHROPIC_API_KEY=

# Optional — legacy social-content worker placeholder
OPENAI_API_KEY=

# Resend for daily digest emails
RESEND_API_KEY=
DIGEST_FROM_EMAIL=your-cmo@example.com

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=

# Instagram Webhooks
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# Admin
ADMIN_EMAIL=admin@example.com
