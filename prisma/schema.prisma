generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth.js (Prisma adapter) — keep field names compatible with @auth/prisma-adapter
// ---------------------------------------------------------------------------

model User {
  id                 String    @id @default(cuid())
  email              String?   @unique
  name               String?
  autoPost           Boolean   @default(false)
  digestEnabled      Boolean   @default(true)
  onboardingComplete Boolean   @default(false)
  createdAt          DateTime  @default(now())
  emailVerified      DateTime?
  image              String?
  updatedAt          DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  oauthTokens    OAuthToken[]
  products       Product[]
  scannedPosts   ScannedPost[]
  generatedPosts GeneratedPost[]
  brand            Brand?
  weeklyPlans      WeeklyPlan[]
  plannedPosts     PlannedPost[]
  cmoInstructions  CMOInstruction[]
  competitorPosts  CompetitorPost[]
  subscription     Subscription?

  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// App domain
// ---------------------------------------------------------------------------

enum OAuthProvider {
  instagram
  twitter
}

model OAuthToken {
  id           String        @id @default(cuid())
  userId       String
  provider     OAuthProvider
  accessToken  String        @db.Text
  refreshToken String?       @db.Text
  expiresAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([expiresAt])
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  url         String
  title       String
  description String?  @db.Text
  price       Decimal? @db.Decimal(12, 2)
  images      String[]
  rawHtml     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedPosts  GeneratedPost[]

  @@index([userId])
  @@index([userId, createdAt])
}

model ScannedPost {
  id              String        @id @default(cuid())
  userId          String
  provider        OAuthProvider
  postId          String
  caption         String?       @db.Text
  mediaUrl        String?
  likes           Int           @default(0)
  comments        Int           @default(0)
  shares          Int           @default(0)
  engagementRate  Float         @default(0)
  createdAt       DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, postId])
  @@index([userId])
  @@index([userId, provider])
  @@index([userId, createdAt])
  @@index([userId, engagementRate])
}

model FormatTemplate {
  id                String   @id @default(cuid())
  scannedPostIds    String[]
  hookType          String
  structurePattern  String   @db.Text
  ctaStyle          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  generatedPosts GeneratedPost[]

  @@index([createdAt])
}

enum GeneratedPostStatus {
  draft
  approved
  posted
  failed
  rejected
}

model GeneratedPost {
  id               String              @id @default(cuid())
  userId           String
  productId        String
  formatTemplateId String
  caption          String              @db.Text
  threadDraft      String?             @db.Text
  slidesCopy       String[]
  platform         OAuthProvider       @default(instagram)
  status           GeneratedPostStatus @default(draft)
  postError        String?             @db.Text
  scheduledAt      DateTime?
  postedAt         DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  formatTemplate FormatTemplate @relation(fields: [formatTemplateId], references: [id], onDelete: Restrict)
  plannedPosts   PlannedPost[]
  postMetrics    PostMetrics[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([scheduledAt])
}

model Brand {
  id               String   @id @default(cuid())
  userId           String   @unique
  name             String
  website          String?
  industry         String?
  targetAudience   String   @db.Text
  brandVoice       String   @db.Text
  competitors      String[]
  goals            String[]
  contentPillars   String[]
  avoidTopics      String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyPlans      WeeklyPlan[]

  @@index([userId])
}

enum WeeklyPlanStatus {
  active
  completed
  overridden
}

model WeeklyPlan {
  id         String            @id @default(cuid())
  userId     String
  brandId    String
  weekOf     DateTime
  summary    String            @db.Text
  status     WeeklyPlanStatus  @default(active)
  createdAt  DateTime          @default(now())

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand      Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  plannedPosts PlannedPost[]

  @@index([userId])
  @@index([brandId])
  @@index([userId, weekOf])
  @@unique([userId, weekOf])
}

enum PlannedPostStatus {
  planned
  generating
  draft
  approved
  posted
  failed
  skipped
}

model PlannedPost {
  id               String             @id @default(cuid())
  weeklyPlanId     String
  userId           String
  platform         OAuthProvider
  contentType      String
  topic            String
  angle            String
  reasoning        String             @db.Text
  scheduledDay     String
  scheduledAt      DateTime?
  priority         String
  status           PlannedPostStatus  @default(planned)
  generatedPostId  String?
  createdAt        DateTime           @default(now())

  weeklyPlan       WeeklyPlan         @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedPost    GeneratedPost?     @relation(fields: [generatedPostId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([weeklyPlanId])
  @@index([status])
  @@index([scheduledAt])
}

model PostMetrics {
  id               String        @id @default(cuid())
  generatedPostId  String
  platform         OAuthProvider
  likes            Int           @default(0)
  comments         Int           @default(0)
  shares           Int           @default(0)
  saves            Int           @default(0)
  reach            Int?
  engagementRate   Float         @default(0)
  measuredAt       DateTime
  createdAt        DateTime      @default(now())

  generatedPost    GeneratedPost @relation(fields: [generatedPostId], references: [id], onDelete: Cascade)

  @@index([generatedPostId])
  @@index([platform])
  @@index([measuredAt])
}

model CMOInstruction {
  id         String   @id @default(cuid())
  userId     String
  instruction String  @db.Text
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, active])
}

model CompetitorPost {
  id               String        @id @default(cuid())
  userId           String
  competitorDomain String
  platform         OAuthProvider
  postUrl          String
  caption          String?       @db.Text
  engagementRate   Float         @default(0)
  postedAt         DateTime
  analysisNotes    String?       @db.Text
  createdAt        DateTime      @default(now())

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, competitorDomain])
  @@index([userId, platform])
}

enum Plan {
  free
  starter
  pro
}

enum SubscriptionStatus {
  active
  past_due
  canceled
}

model Subscription {
  id                  String             @id @default(cuid())
  userId              String             @unique
  stripeCustomerId    String?
  stripePriceId       String?
  stripeSubscriptionId String?
  plan                Plan               @default(free)
  status              SubscriptionStatus @default(active)
  currentPeriodEnd    DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}
